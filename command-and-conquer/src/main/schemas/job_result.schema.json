{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JobResult",
  "description": "Schema for job_result.json — matches the OUTPUT_FORMAT.md contract",
  "type": "object",
  "required": ["tool", "model", "status", "summary", "risks", "manual_validation", "commit_hash", "created_at"],
  "properties": {
    "tool": { "type": "string" },
    "model": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["success", "complete", "partial", "failed"]
    },
    "summary": { "type": "string" },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "severity"],
        "properties": {
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "manual_validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "result"],
        "properties": {
          "check": { "type": "string" },
          "result": { "type": "string", "enum": ["passed", "failed", "skipped", "uncertain", "PASSED", "FAILED", "SKIPPED"] },
          "notes": { "type": "string" }
        }
      }
    },
    "commit_hash": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
